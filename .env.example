# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://copytrader:secret@postgres:5432/copytrader
POSTGRES_PASSWORD=secret

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-at-least-32-random-characters
ENCRYPTION_KEY=change-me-32-chars-encryption-key!!

# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CopyTrader Pro <noreply@yourdomain.com>

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Copy Engine ─────────────────────────────────────────────────────────────
COPY_POLL_INTERVAL_MS=100
COPY_RETRY_COUNT=3
COPY_RETRY_DELAY_MS=500
