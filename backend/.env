DATABASE_URL=sqlite+aiosqlite:///./copytrader.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-key-32-chars-minimum!!
ENCRYPTION_KEY=dev-encryption-32-chars-minimum!
APP_ENV=development
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# MetaApi — TON token central (un seul pour tous tes clients)
# METAAPI_TOKEN=your_token_here

COPY_POLL_INTERVAL_MS=100
COPY_RETRY_COUNT=3
COPY_RETRY_DELAY_MS=500

# Stripe (add your keys to enable billing)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_PRO=price_xxx
FRONTEND_URL=http://localhost:5173
